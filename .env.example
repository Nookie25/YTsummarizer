# Which AI provider powers the summary + chat. Defaults to "anthropic" if unset.
# AI_PROVIDER=anthropic

# --- Anthropic (used when AI_PROVIDER=anthropic, the default) ---
# Get a key: https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=

# --- OpenAI (used when AI_PROVIDER=openai) ---
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional — override the default model (gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional — Supadata key for transcript fetching from cloud IPs that YouTube
# blocks (needed on Vercel if direct fetching fails): https://supadata.ai
SUPADATA_API_KEY=

# Optional — Upstash Redis for durable per-IP rate limiting (recommended in
# production; without these, rate limiting falls back to an in-memory limiter
# that doesn't persist across serverless instances). Create a database at
# https://upstash.com, then copy the REST URL/token from its dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — public origin used for sitemap.xml, robots.txt, and OG image URLs.
# Defaults to https://memotube.com. Set this on Vercel preview deploys if you
# want their sitemap/OG URLs to point at the preview instead of production.
# NEXT_PUBLIC_SITE_URL=https://memotube.com

# Optional — Sentry error monitoring. Leave blank to keep Sentry disabled
# (local dev, or any deploy where you don't want it). Create a project at
# https://sentry.io and copy the DSN from Project Settings → Client Keys.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for readable stack traces (source-map upload at build time).
# Create an auth token under Sentry → Settings → Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
